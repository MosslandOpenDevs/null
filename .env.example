# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
TAVILY_API_KEY=tvly-...

# Database
POSTGRES_USER=null_user
POSTGRES_PASSWORD=null_pass
POSTGRES_DB=null_db
# Inside docker-compose (service hostname, container port):
DATABASE_URL=postgresql+asyncpg://null_user:null_pass@postgres:5432/null_db
# From the host machine use: postgresql+asyncpg://null_user:null_pass@localhost:3310/null_db

# Redis
# Inside docker-compose: redis://redis:6379/0 — from the host: redis://localhost:3311/0
REDIS_URL=redis://redis:6379/0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3301

# Security
# Token clients must send as X-API-Key on write endpoints (world create/start,
# interventions). Leave empty + ALLOW_ANONYMOUS_WRITES=true only for local dev.
API_WRITE_TOKEN=change-me
ALLOW_ANONYMOUS_WRITES=false
# Comma-separated allowed origins, or *
CORS_ORIGINS=*

# Autonomous world creation (consumes LLM budget continuously)
AUTO_GENESIS_ENABLED=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3301
NEXT_PUBLIC_WS_URL=ws://localhost:3301
